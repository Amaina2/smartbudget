NODE_ENV=production
PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=smartbudget

# Generate a strong random secret before production.
JWT_SECRET=replace-with-strong-random-secret

# Frontend origin allowed by CORS
CLIENT_ORIGIN=https://your-frontend-domain.com

# Optional: set cookie domain if API/frontend are subdomains of same parent.
# COOKIE_DOMAIN=.your-domain.com

# Optional — Safaricom Daraja (sandbox)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSWORD=
# MPESA_TIMESTAMP=
# MPESA_CALLBACK_URL=https://your-domain/api/mpesa/callback
